%  9. Module 1, Project 11
% 1. Define x and Q(x)
x = 0:0.5:20;
Q = -0.05*x.^2 + 1.2*x + 5;

% 2. Define threshold T(x)
T = 0.8*x + 3;

% 3. Plot both
figure; hold on;
plot(x, Q, 'b-', 'LineWidth', 2);
plot(x, T, 'r--', 'LineWidth', 2);
xlabel('x'); ylabel('Value');
legend('Q(x)', 'T(x)', 'Location', 'Best');
grid on;

% 4. Find pass/fail intervals
pass_idx = find(Q >= T);

% Convert indices to contiguous x-intervals
d = diff(pass_idx);
breaks = [0 find(d > 1) length(pass_idx)];
intervals = [];

for k = 1:length(breaks)-1
    start_i = pass_idx(breaks(k)+1);
    end_i   = pass_idx(breaks(k+1));
    intervals = [intervals; x(start_i) x(end_i)];
end

disp('Pass intervals (x ranges):');
disp(intervals);
Pass intervals (x ranges):
