clear; clc;

% -----------------------------
% Simulation Parameters
% -----------------------------
dt = 0.01;          % time step (s)
T  = 10;            % total simulation time (s)
t  = 0:dt:T;

% Motion constraints
v_max = 1.5;        % max velocity (m/s)
v_min = -1.5;       % min velocity (reverse)
a_max = 1.0;        % max acceleration (m/s^2)
a_min = -1.0;       % min acceleration (m/s^2)

% Desired acceleration profile (example)
a_cmd = 0.8 * ones(size(t));  
a_cmd(t > 4 & t <= 7) = -1.2;   % braking phase
a_cmd(t > 7) = 0.5;             % accelerate again

% State variables
x = zeros(size(t));   % position
v = zeros(size(t));   % velocity

% Event logs
stop_events = [];
reverse_events = [];

% -----------------------------
% Simulation Loop
% -----------------------------
for k = 2:length(t)

    % 1. Apply acceleration command with limits
    a = min(max(a_cmd(k), a_min), a_max);

    % 2. Update velocity
    v(k) = v(k-1) + a * dt;

    % 3. Enforce velocity limits
    if v(k) > v_max
        v(k) = v_max;
    elseif v(k) < v_min
        v(k) = v_min;
    end

    % 4. Update position
    x(k) = x(k-1) + v(k) * dt;

    % -----------------------------
    % Event Detection
    % -----------------------------
    % Detect stopping (velocity crosses zero)
    if v(k-1) ~= 0 && abs(v(k)) < 1e-4
        stop_events(end+1) = t(k);
    end

    % Detect reversing (sign change)
    if sign(v(k)) ~= sign(v(k-1)) && v(k) ~= 0
        reverse_events(end+1) = t(k);
    end
end

