function dataTable = simulateGymData(startDate, nWeeks)
% simulateGymData Simulates hourly gym occupancy for nWeeks starting at startDate.
%
% Output:
%   dataTable: table with variables datetime, weekday, hour, occupancy

    % Parameters
    hoursOpen = 6:23; % 6:00 to 23:00
    nDays = 7 * nWeeks;
    nHoursPerDay = numel(hoursOpen);
    nRows = nDays * nHoursPerDay;

    datetimeVec = NaT(nRows,1);
    weekdayVec = strings(nRows,1);
    hourVec = zeros(nRows,1);
    occupancyVec = zeros(nRows,1);

    idx = 1;

    for d = 0:nDays-1
        currentDate = startDate + days(d);
        for h = hoursOpen
            datetimeVec(idx) = datetime(year(currentDate), month(currentDate), day(currentDate), h, 0, 0);
            weekdayVec(idx) = string(day(currentDate, 'name'));
            hourVec(idx) = h;

            % Base pattern: busier evenings, moderate midday, low early morning
            base = 20;
            if h >= 17 && h <= 20
                base = 70; % peak
            elseif h >= 12 && h <= 14
                base = 45; % lunchtime moderate
            elseif h <= 8
                base = 15; % early low
            else
                base = 30; % default moderate
            end

            % Weekend effect: slightly lower usage
            if ismember(weekdayVec(idx), ["Saturday","Sunday"])
                base = base * 0.8;
            end

            % Add random noise
            occ = base + 10*randn;
            occ = max(0, min(100, occ)); % clamp between 0 and 100

            occupancyVec(idx) = occ;
            idx = idx + 1;
        end
    end

    weekdayCat = categorical(weekdayVec, ...
        {'Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'}, ...
        'Ordinal', true);

    dataTable = table(datetimeVec, weekdayCat, hourVec, occupancyVec, ...
        'VariableNames', {'datetime','weekday','hour','occupancy'});
end
function results = analyzeGymUsage(T)
% analyzeGymUsage Computes peaks, off-peaks, and weekly trends.
%
% Input:
%   T: table with datetime, weekday, hour, occupancy
%
% Output:
%   results: struct with metrics and trend info

    occ = T.occupancy;
    hr = T.hour;

    % Basic stats
    results.meanOccupancy = mean(occ);
    results.stdOccupancy  = std(occ);
    [results.maxOccupancy, idxMax] = max(occ);
    [results.minOccupancy, idxMin] = min(occ);
    results.maxTime = T.datetime(idxMax);
    results.minTime = T.datetime(idxMin);

    % Correlation between hour and occupancy
    results.corrHourOcc = corr(double(hr), occ);

    % Average occupancy by hour (for peak/off-peak windows)
    [hourGroups, ~, hourIdx] = unique(hr);
    meanByHour = accumarray(hourIdx, occ, [], @mean);

    % Find peak and off-peak hour ranges (simple: top 3 and bottom 3 hours)
    [~, sortIdx] = sort(meanByHour, 'descend');
    peakHours = hourGroups(sortIdx(1:3));
    offPeakHours = hourGroups(sortIdx(end-2:end));

    % Store as datetime-of-day windows (just for printing)
    results.peakHourWindow = [datetime(0,0,0, min(peakHours),0,0), ...
                              datetime(0,0,0, max(peakHours),0,0)];
    results.offPeakHourWindow = [datetime(0,0,0, min(offPeakHours),0,0), ...
                                 datetime(0,0,0, max(offPeakHours),0,0)];

    % Weekly trend: mean occupancy by weekday
    [weekdayCats, ~, wIdx] = unique(T.weekday);
    meanByWeekday = accumarray(wIdx, occ, [], @mean);
    results.weekdayCats = weekdayCats;
    results.meanByWeekday = meanByWeekday;

    % Hourly pattern by weekday (for comparison plot)
    % Pivot: rows = hour, cols = weekday
    hoursUnique = unique(hr);
    nH = numel(hoursUnique);
    nW = numel(weekdayCats);
    hourlyWeekdayMean = nan(nH, nW);

    for iW = 1:nW
        for iH = 1:nH
            mask = (T.weekday == weekdayCats(iW)) & (T.hour == hoursUnique(iH));
            if any(mask)
                hourlyWeekdayMean(iH, iW) = mean(T.occupancy(mask));
            end
        end
    end

    results.hoursUnique = hoursUnique;
    results.hourlyWeekdayMean = hourlyWeekdayMean;

    % Simple trend model: occupancy vs hour (linear fit) for RMSE
    X = [ones(size(hr)), double(hr)];
    beta = X \ occ;
    occPred = X * beta;
    results.RMSE_hourModel = sqrt(mean((occ - occPred).^2));
end
