%  10. Module 2, Project 18
%% CPU Temperature Rise and Throttling Simulation

clear; clc; close all;

% --- Simulation Parameters ---
dt = 0.1;                 % time step (s)
t_end = 200;              % total simulation time (s)
t = 0:dt:t_end;

% Thermal model parameters
T_ambient = 35;           % ambient temperature (°C)
T = T_ambient;            % initial CPU temperature
C = 50;                   % thermal capacitance (J/°C)
R = 0.5;                  % thermal resistance (°C/W)

% Power model
P_full = 45;              % CPU power at full load (W)
P_throttled = 20;         % power when throttled (W)

% Throttling threshold
T_limit = 85;             % safe temperature limit (°C)

% Data storage
T_hist = zeros(size(t));
P_hist = zeros(size(t));
perf_hist = zeros(size(t));  % relative performance (1 = full speed)

% --- Simulation Loop ---
throttled = false;

for i = 1:length(t)
    
    % Determine power based on throttling
    if T >= T_limit
        throttled = true;
    elseif T < T_limit - 5
        throttled = false;  % hysteresis to avoid rapid toggling
    end
    
    if throttled
        P = P_throttled;
        perf = 0.5;  % assume 50% performance when throttled
    else
        P = P_full;
        perf = 1.0;
    end
    
    % Thermal model: dT/dt = (P - (T - T_ambient)/R) / C
    dTdt = (P - (T - T_ambient)/R) / C;
    T = T + dTdt * dt;
    
    % Store data
    T_hist(i) = T;
    P_hist(i) = P;
    perf_hist(i) = perf;
end

%% --- Plot Results ---
figure;
subplot(2,1,1);
plot(t, T_hist, 'LineWidth', 2); hold on;
yline(T_limit, 'r--', 'Throttling Limit');
xlabel('Time (s)');
ylabel('Temperature (°C)');
title('CPU Temperature Over Time');
grid on;

subplot(2,1,2);
plot(t, perf_hist, 'LineWidth', 2);
xlabel('Time (s)');
ylabel('Relative Performance');
title('Performance (1 = Full Speed, 0.5 = Throttled)');
grid on;
